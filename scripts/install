#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd -P)"
PROJECT_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd -P)"
ROOT="${HOME}/.local/opt/chatwork-cli"

while [[ $# -gt 0 ]]; do
  case "$1" in
    --path)
      if [[ $# -lt 2 ]]; then
        printf 'error: --path にはインストール先が必要だよ\n' >&2
        exit 1
      fi
      ROOT="$2"
      shift 2
      ;;
    -h|--help)
      cat <<'EOF'
usage: ./scripts/install [--path INSTALL_ROOT]

options:
  --path  インストール先の root を上書きする
          既定値: ~/.local/opt/chatwork-cli
EOF
      exit 0
      ;;
    *)
      printf 'error: 未知の引数だよ: %s\n' "$1" >&2
      exit 1
      ;;
  esac
done

cargo install --path "${PROJECT_ROOT}" --root "${ROOT}" --force

INSTALLED_BIN="${ROOT}/bin/chatwork"
printf 'installed: %s\n' "${INSTALLED_BIN}"

# シェル補完を自動で配置する。対象ディレクトリが存在する場合のみ。
ZSH_FUNC_DIR="${HOME}/.zfunc"
if [ -d "${ZSH_FUNC_DIR}" ]; then
  "${INSTALLED_BIN}" completion zsh > "${ZSH_FUNC_DIR}/_chatwork"
  printf 'updated zsh completion: %s\n' "${ZSH_FUNC_DIR}/_chatwork"
fi

BASH_COMP_DIR="${HOME}/.local/share/bash-completion/completions"
if [ -d "${BASH_COMP_DIR}" ]; then
  "${INSTALLED_BIN}" completion bash > "${BASH_COMP_DIR}/chatwork"
  printf 'updated bash completion: %s\n' "${BASH_COMP_DIR}/chatwork"
fi
