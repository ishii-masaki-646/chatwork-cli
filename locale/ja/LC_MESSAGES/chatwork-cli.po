msgid ""
msgstr ""
"Language: ja\n"
"Content-Type: text/plain; charset=UTF-8\n"

msgid "No templates are registered."
msgstr "テンプレートは登録されていません。"

msgid "Set the `{token_env}` environment variable."
msgstr "環境変数 `{token_env}` を設定してください。"

msgid "Sent the message. room_id={room_id} message_id={message_id}"
msgstr "送信しました。room_id={room_id} message_id={message_id}"

msgid "Template `{name}` was not found."
msgstr "テンプレート `{name}` が見つかりません。"

msgid "Template `{name}` must specify exactly one of body or body_file."
msgstr "テンプレート `{name}` では body または body_file のいずれか一方のみを指定してください。"

msgid "Specify one of --room, template room_id, or default_room_id."
msgstr "--room、テンプレートの room_id、default_room_id のいずれかを指定してください。"

msgid "`{item}` must use KEY=VALUE format."
msgstr "`{item}` は KEY=VALUE 形式で指定してください。"

msgid "Variable names cannot be empty: `{item}`"
msgstr "変数名は空にできません: `{item}`"

msgid "Missing closing `}}` for template placeholder."
msgstr "テンプレートの `{{` に対応する `}}` がありません。"

msgid "Empty placeholder names are not allowed."
msgstr "空の変数名は使用できません。"

msgid "Variable `{key}` is not set."
msgstr "変数 `{key}` が指定されていません。"

msgid "HOME is unavailable. Specify `--config`."
msgstr "HOME を取得できないため、`--config` を指定してください。"

msgid "Failed to read config file: {path}"
msgstr "設定ファイルを読み込めませんでした: {path}"

msgid "Failed to parse TOML config: {path}"
msgstr "設定ファイルの TOML を解析できませんでした: {path}"

msgid "Failed to read template body file: {path}"
msgstr "テンプレート本文ファイルを読み込めませんでした: {path}"

msgid "At least one template must be defined."
msgstr "テンプレートが 1 件も定義されていません。"

msgid "Failed to send request to Chatwork API."
msgstr "Chatwork API へのリクエストに失敗しました。"

msgid "Failed to read response body from Chatwork API."
msgstr "Chatwork API のレスポンスを読み取れませんでした。"

msgid "Chatwork API returned an error: status={status} body={body}"
msgstr "Chatwork API がエラーを返しました: status={status} body={body}"

msgid "The response does not contain message_id."
msgstr "レスポンスに message_id が含まれていません。"

msgid "Failed to parse message_id from the response."
msgstr "レスポンスの message_id を最後まで読み取れませんでした。"

msgid "Ambiguous subcommand prefix `{prefix}`: {matches}"
msgstr "サブコマンドの prefix `{prefix}` があいまいです: {matches}"

msgid "The response does not contain download_url."
msgstr "レスポンスに download_url が含まれていません。"

msgid "Specify the room URL either as an argument or with --chat-url, not both."
msgstr "ルーム URL は位置引数または --chat-url のどちらか一方だけを指定してください。"

msgid "Specify either a room URL or --room-id, not both."
msgstr "ルーム URL か --room-id のどちらか一方だけを指定してください。"

msgid "Specify either a room URL or --room-id."
msgstr "ルーム URL か --room-id を指定してください。"

msgid "Specify the message URL either as an argument or with --chat-url, not both."
msgstr "メッセージ URL は位置引数または --chat-url のどちらか一方だけを指定してください。"

msgid "Specify both --room-id and --message-id."
msgstr "--room-id と --message-id は両方指定してください。"

msgid "Specify either a message URL or the pair of --room-id and --message-id."
msgstr "メッセージ URL か、--room-id と --message-id の組み合わせのどちらかを指定してください。"

msgid "Specify the chat URL either as an argument or with --chat-url, not both."
msgstr "チャット URL は位置引数または --chat-url のどちらか一方だけを指定してください。"

msgid "Specify both --room-id and --file-id."
msgstr "--room-id と --file-id は両方指定してください。"

msgid "Specify either --chat-url or the pair of --room-id and --file-id."
msgstr "--chat-url か、--room-id と --file-id の組み合わせのどちらかを指定してください。"

msgid "The URL must contain `#!rid<room_id>` or `#!rid<room_id>-<message_id>`."
msgstr "URL には `#!rid<room_id>` または `#!rid<room_id>-<message_id>` を含めてください。"

msgid "Failed to parse room_id from chat URL."
msgstr "チャット URL から room_id を解析できませんでした。"

msgid "Failed to parse message_id from chat URL."
msgstr "チャット URL から message_id を解析できませんでした。"

msgid "Missing closing `]` for download tag."
msgstr "download タグの閉じ `]` がありません。"

msgid "Failed to parse file_id from download tag: {tag}"
msgstr "download タグから file_id を解析できませんでした: {tag}"

msgid "Missing closing `[/download]` for download tag."
msgstr "download タグの閉じ `[/download]` がありません。"

msgid "The message does not contain a download tag."
msgstr "メッセージに download タグが含まれていません。"

msgid "Multiple download tags were found:"
msgstr "複数の download タグが見つかりました:"

msgid "Select numbers, ranges, or [A]ll (default: All):"
msgstr "番号、範囲、または [A]ll を選んでください（既定: All）:"

msgid "Failed to read selection from stdin."
msgstr "標準入力から選択内容を読み取れませんでした。"

msgid "Invalid selection. Enter numbers, ranges, commas, or A."
msgstr "選択が不正です。番号、範囲、カンマ区切り、または A を入力してください。"

msgid "Specify either --output or --out-dir, not both."
msgstr "--output と --out-dir は同時に指定できません。"

msgid "Downloading multiple files requires --out-dir, an existing directory passed to --output, or no output path."
msgstr "複数ファイルをダウンロードする場合は、--out-dir、既存ディレクトリを指定した --output、または出力パス未指定のいずれかを使ってください。"

msgid "Failed to download file from Chatwork."
msgstr "Chatwork からファイルをダウンロードできませんでした。"

msgid "Failed to read downloaded file body."
msgstr "ダウンロードしたファイルの内容を読み取れませんでした。"

msgid "Failed to serialize output as JSON."
msgstr "出力を JSON としてシリアライズできませんでした。"

msgid "Failed to load .env file."
msgstr ".env ファイルを読み込めませんでした。"

msgid "Failed to parse Chatwork API response JSON."
msgstr "Chatwork API のレスポンス JSON を解析できませんでした。"

msgid "Required argument is missing: {arg}"
msgstr "必須の引数が不足しています: {arg}"

msgid "Required argument is missing."
msgstr "必須の引数が不足しています。"

msgid "Unknown argument: {arg}"
msgstr "不明な引数です: {arg}"

msgid "Unknown argument."
msgstr "不明な引数です。"

msgid "A value is required for {arg}."
msgstr "{arg} には値が必要です。"

msgid "A value is required."
msgstr "値を指定してください。"

msgid "Invalid value for {arg}: {value}"
msgstr "{arg} の値が不正です: {value}"

msgid "Invalid value for {arg}."
msgstr "{arg} の値が不正です。"

msgid "Invalid value."
msgstr "値が不正です。"

msgid "The number of values is invalid for {arg}."
msgstr "{arg} に指定された値の数が不正です。"

msgid "The number of values is invalid."
msgstr "値の数が不正です。"

msgid "Use = when specifying a value for {arg}."
msgstr "{arg} に値を指定するときは = を使ってください。"

msgid "Use = when specifying the value."
msgstr "値を指定するときは = を使ってください。"

msgid "Unknown subcommand: {subcommand}"
msgstr "不明なサブコマンドです: {subcommand}"

msgid "Unknown subcommand."
msgstr "不明なサブコマンドです。"

msgid "A subcommand is required."
msgstr "サブコマンドを指定してください。"

msgid "A subcommand or URL is required."
msgstr "サブコマンドまたは URL を指定してください。"

msgid "A command is required."
msgstr "コマンドを指定してください。"

msgid "Argument {arg} cannot be used together with {other}."
msgstr "{arg} は {other} と同時に使えません。"

msgid "The specified arguments cannot be used together."
msgstr "指定された引数の組み合わせは使えません。"
